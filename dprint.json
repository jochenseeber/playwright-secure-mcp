{
    "$schema": "https://dprint.dev/schemas/v0.json",
    "excludes": [
        "**/.serena"
    ],
    "includes": [
        "**/*.json",
        "**/*.md",
        "**/*.txt",
        "**/*.yaml",
        "**/*.yml"
    ],
    "indentWidth": 4,
    "json": {},
    "markdown": {
        "associations": [
            "**/*.md",
            "**/*.txt"
        ],
        "lineWidth": 79,
        "textWrap": "always"
    },
    "newLineKind": "lf",
    "plugins": [
        "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
        "https://plugins.dprint.dev/json-0.21.3.wasm",
        "https://plugins.dprint.dev/markdown-0.22.1.wasm"
    ],
    "useTabs": false,
    "yaml": {
        "formatComments": true,
        "indentWidth": 2,
        "printWidth": 120,
        "proseWrap": "always",
        "quotes": "forceDouble"
    }
}
