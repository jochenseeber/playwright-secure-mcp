#!/usr/bin/env bash
# Fake `op` CLI for ItemLocator specs.
#   op item get <name> [--vault V] --format=json
#   op item list (--tags T | --categories Login) [--vault V] --format=json
sub="$2"; target="$3"
vault=""; account=""; category=""
for ((i=1;i<=$#;i++)); do
  if [ "${!i}" = "--vault" ]; then j=$((i+1)); vault="${!j}"; fi
  if [ "${!i}" = "--account" ]; then j=$((i+1)); account="${!j}"; fi
  if [ "${!i}" = "--categories" ]; then j=$((i+1)); category="${!j}"; fi
done

if [ "$1" = "item" ] && [ "$sub" = "get" ] && [ "$target" = "Scoped" ]; then
  if [ "$vault" = "privatevault" ]; then
    printf '{"id":"scoped1","title":"Scoped","vault":{"id":"privatevault"},"urls":[]}\n'
    exit 0
  fi
  printf 'op: more than one item matches\n' >&2
  exit 1
fi
if [ "$1" = "item" ] && [ "$sub" = "get" ] && [ "$target" = "AccountProbe" ]; then
  if [ "$account" = "acct1" ]; then
    printf '{"id":"acct-item","title":"Probe","vault":{"id":"vault1"},"urls":[]}\n'
    exit 0
  fi
  printf 'op: expected --account acct1\n' >&2
  exit 1
fi
if [ "$1" = "item" ] && [ "$sub" = "get" ] && [ "$target" = "TokenProbe" ]; then
  if [ -n "$OP_SERVICE_ACCOUNT_TOKEN" ] && [ -z "$account" ]; then
    printf '{"id":"tok-item","title":"P","vault":{"id":"vault1"},"urls":[]}\n'
    exit 0
  fi
  printf 'op: expected OP_SERVICE_ACCOUNT_TOKEN without --account\n' >&2
  exit 1
fi
if [ "$1" = "item" ] && [ "$sub" = "get" ]; then
  printf '{"id":"item1","title":"Netflix","vault":{"id":"vault1"},"urls":[{"href":"https://netflix.com"}]}\n'
  exit 0
fi
if [ "$1" = "item" ] && [ "$sub" = "list" ]; then
  for ((i=1;i<=$#;i++)); do
    if [ "${!i}" = "--tags" ]; then j=$((i+1)); tag="${!j}"; fi
  done
  if [ "$tag" = "badshape" ]; then
    printf '{}\n'
    exit 0
  fi
  if [ "$tag" = "apikey" ]; then
    printf '[{"id":"item1","title":"API","vault":{"id":"vault1"}},{"id":"item2","title":"API2","vault":{"id":"vault1"}}]\n'
    exit 0
  fi
  if [ -n "$tag" ]; then printf '[]\n'; exit 0; fi
  if [ "$category" = "Login" ]; then
    printf '[{"id":"login1","title":"Example","vault":{"id":"vault1"},"urls":[{"href":"https://example.com/login"}]}]\n'
    exit 0
  fi
  printf 'op: item list requires --tags or --categories Login\n' >&2
  exit 1
fi
exit 1
