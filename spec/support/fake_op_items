#!/usr/bin/env bash
# Fake `op` CLI for TokenFetcher specs. Supports:
#   op item list --tags <TAG> --format=json [--account X]
#   op item get <ID> --fields label=credential --reveal --format=json [--account X]
if [ "$1" = "item" ] && [ "$2" = "list" ]; then
  shift 2
  tag=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --tags)
        tag="$2"
        shift 2
        ;;
      --account)
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  if [ "$tag" = "apikey" ]; then
    printf '[{"id":"item123","title":"API Key"}]\n'
  else
    printf '[]\n'
  fi
  exit 0
fi
if [ "$1" = "item" ] && [ "$2" = "get" ] && [ "$3" = "item123" ]; then
  printf '[{"id":"credential","label":"credential","value":"ops_service_token","type":"CONCEALED"}]\n'
  exit 0
fi
exit 1
