#!/usr/bin/env bash
# Fake `op` CLI shared by the ItemLocator/finder and TokenFetcher specs.
# ItemLocator:
#   op item list --categories Login [--tags T] [--vault V] --format=json
#   op item get - --reveal --format=json   (specifiers as JSON array on stdin)
# TokenFetcher:
#   op item list --tags <TAG> --format=json [--account X]
#   op item get item123 --fields label=credential --reveal --format=json
category=""
login_tag=""
account=""
for ((i=1;i<=$#;i++)); do
  [ "${!i}" = "--categories" ] && { j=$((i+1)); category="${!j}"; }
  [ "${!i}" = "--tags" ] && { j=$((i+1)); login_tag="${!j}"; }
  [ "${!i}" = "--account" ] && { j=$((i+1)); account="${!j}"; }
done

if [ "$1" = "item" ] && [ "$2" = "list" ] && [ "$category" = "Login" ]; then
  # Service-token mode: the token must arrive via the environment and
  # --account must be omitted. Keyed on the spec's exact sentinel token value
  # (not mere presence) so a real OP_SERVICE_ACCOUNT_TOKEN inherited from the
  # dev/CI shell cannot flip the token-less specs. Returns a distinct item id
  # so the spec can tell this path apart from the plain (token-less) listing.
  if [ "$OP_SERVICE_ACCOUNT_TOKEN" = "tok" ]; then
    [ -n "$account" ] && exit 1
    printf '[{"id":"svc1","title":"Service","category":"LOGIN","vault":{"id":"v1"},"urls":[{"href":"https://example.com/login"}],"tags":["work"]}]\n'
    exit 0
  fi
  # The only login carries the tag "work"; honor --tags so tag narrowing is real.
  if [ -z "$login_tag" ] || [ "$login_tag" = "work" ]; then
    printf '[{"id":"login1","title":"Example","category":"LOGIN","vault":{"id":"v1"},"urls":[{"href":"https://example.com/login"}],"tags":["work"]}]\n'
  else
    printf '[]\n'
  fi
  exit 0
fi

if [ "$1" = "item" ] && [ "$2" = "get" ] && [ "$3" = "-" ]; then
  input="$(cat)"
  # Real `op item get -` prints a STREAM of concatenated top-level JSON objects
  # (one per requested item), NOT a JSON array. Mirror that exactly.
  case "$input" in
    *login2*)
      # Several LOGIN items requested -> two concatenated login objects.
      printf '{"id":"login1","title":"Example","category":"LOGIN","vault":{"id":"v1"},"urls":[{"href":"https://example.com/login"}],"tags":["work"],"fields":[{"id":"password","type":"CONCEALED","purpose":"PASSWORD","label":"password","value":"pw"}]}\n{"id":"login2","title":"Second","category":"LOGIN","vault":{"id":"v1"},"urls":[{"href":"https://example.com/login"}],"tags":[],"fields":[{"id":"password","type":"CONCEALED","purpose":"PASSWORD","label":"password","value":"pw2"}]}\n'
      exit 0
      ;;
    *login1*)
      # One login plus one non-login (must be dropped) -- concatenated objects.
      printf '{"id":"login1","title":"Example","category":"LOGIN","vault":{"id":"v1"},"urls":[{"href":"https://example.com/login"}],"tags":["work"],"sections":[{"id":"sec1","label":"More"}],"fields":[{"id":"username","type":"STRING","purpose":"USERNAME","label":"username","value":"alice"},{"id":"password","type":"CONCEALED","purpose":"PASSWORD","label":"password","value":"pw"},{"id":"custom","type":"STRING","label":"Token","section":{"id":"sec1"},"value":"k"}]}\n{"id":"note1","title":"Note","category":"SECURE_NOTE","vault":{"id":"v1"},"fields":[]}\n'
      exit 0
      ;;
  esac
  exit 1
fi

if [ "$1" = "item" ] && [ "$2" = "list" ]; then
  shift 2
  tag=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --tags)
        tag="$2"
        shift 2
        ;;
      --account)
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  if [ "$tag" = "apikey" ]; then
    printf '[{"id":"item123","title":"API Key"}]\n'
  else
    printf '[]\n'
  fi
  exit 0
fi
if [ "$1" = "item" ] && [ "$2" = "get" ] && [ "$3" = "item123" ]; then
  printf '[{"id":"credential","label":"credential","value":"ops_service_token","type":"CONCEALED"}]\n'
  exit 0
fi
exit 1
