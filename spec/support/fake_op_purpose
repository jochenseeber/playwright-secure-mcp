#!/usr/bin/env bash
# Fake `op` CLI for SecretResolver purpose-preference specs.
#   op item get <item> --vault V --reveal --format=json
#   op read op://V/<item>/<field>
#
# Item "messy" mimics a form-captured login: several empty fields labelled
# "username"/"password" plus the real purpose=USERNAME/PASSWORD fields, and its
# `op read .../username` is ambiguous and returns empty (the bug being fixed).
# Item "plain" has no purpose fields, so resolution must fall back to `op read`.
if [ "$1" = "item" ] && [ "$2" = "get" ]; then
  item="$3"
  if [ "$item" = "messy" ]; then
    printf '{"fields":[{"id":"","label":"username","value":""},{"id":"username","label":"username","purpose":"USERNAME","value":"real-user"},{"id":"password","label":"password","purpose":"PASSWORD","value":"real-pass"}]}\n'
    exit 0
  fi
  if [ "$item" = "custom" ]; then
    # token: an empty field WITH an id vs a non-empty field WITHOUT an id
    #        (non-empty must win over has-id).
    # code:  two non-empty fields, one with an id and one without
    #        (has-id must win when both are non-empty).
    printf '{"fields":[{"id":"tokid","label":"token","value":""},{"id":"","label":"token","value":"tok-value"},{"id":"","label":"code","value":"no-id-value"},{"id":"codeid","label":"code","value":"with-id-value"}]}\n'
    exit 0
  fi
  printf '{"fields":[{"id":"notesPlain","label":"notesPlain","purpose":"NOTES","value":""}]}\n'
  exit 0
fi
if [ "$1" = "read" ]; then
  ref="${@: -1}"
  case "$ref" in
    *"/messy/username") printf '\n'; exit 0 ;;
    *"/plain/username") printf 'plain-user\n'; exit 0 ;;
    *) printf 'op: error resolving reference\n' >&2; exit 1 ;;
  esac
fi
exit 1
